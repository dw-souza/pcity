# Server
PORT=8080

# Postgres local (docker compose up)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pcity?sslmode=disable

# JWT local — use com o usuário dev (sub: 00000000-0000-4000-8000-000000000001)
# Gere em https://jwt.io com HS256 e payload: {"sub":"00000000-0000-4000-8000-000000000001","role":"authenticated"}
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Cadastro/login local no mobile (POST /v1/dev/auth) — só dev
DEV_AUTH=true
ADMIN_KEY=dev-admin-key

# Google Places API (necessário para indexação)
GOOGLE_PLACES_API_KEY=
